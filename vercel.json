    "src/app/api/agents/chat/websocket/route.ts": { "maxDuration": 300 },
    "src/app/api/agents/email/route.ts": { "maxDuration": 300 },
    "src/app/api/agents/email/deliveryStatus/route.ts": { "maxDuration": 300 },
    "src/app/api/ai/image/route.ts": { "maxDuration": 60 },
